{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chive",
  "version": "0.1.0",
  "identifier": "com.chifeng.chive",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1430",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Chive",
        "width": 800,
        "height": 600,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
